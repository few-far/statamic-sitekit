{
  "name": "few-far/statamic-sitekit",
  "description": "We use Statamic, but we always bolt on these extra batteries + conventions so projects start at our baseline.",
  "type": "library",
  "version": "1.0.0-alpha-23",
  "require-dev": {
    "chrome-php/chrome": "^1.15",
    "laravel/framework": "^12.0 || ^13.0",
    "pestphp/pest": "^4.5",
    "larastan/larastan": "^3.9.5",
    "statamic/cms": "^6.0 || ^5.0",
    "statamic/eloquent-driver": "^5.0 || ^4.0",
    "orchestra/testbench": "^11.1.0"
  },
  "license": "MIT",
  "autoload": {
    "files": [
      "src/Support/helpers.php"
    ],
    "psr-4": {
      "FewFar\\Sitekit\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Thomas Nadin",
      "email": "thomas@fewandfar.co.uk"
    },
    {
      "name": "Maurovic Cachia",
      "email": "mauro@fewandfar.co.uk"
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "FewFar\\Sitekit\\SitekitServiceProvider"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "pixelfear/composer-dist-plugin": true
    }
  }
}
